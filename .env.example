# ─────────────────────────────────────────────────────────────
# Boss Barbearia — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o arquivo .env para o GitHub.
# ─────────────────────────────────────────────────────────────

# Django
DEBUG=False
SECRET_KEY=substitua-por-uma-chave-aleatoria-de-50-chars-aqui

# Hosts separados por vírgula (domínio do Render/Railway)
ALLOWED_HOSTS=localhost,127.0.0.1,seu-app.onrender.com

# Banco de dados — formato: postgres://user:password@host:port/dbname
# Em desenvolvimento local com SQLite, deixe vazio ou use: sqlite:///db.sqlite3
DATABASE_URL=postgres://usuario:senha@host:5432/boss_barbearia

# Configurações opcionais
DJANGO_SETTINGS_MODULE=meu_sistema.settings
